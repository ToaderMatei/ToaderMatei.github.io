---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const CTF_LABEL: Record<string, string> = {
	'itec':        'ITEC 2025 CTF',
	'chronos':     'Chronos Security CTF 2025',
	'learn-it':    'Learn-it CTF',
	'cyberedu':    'CyberEdu / ROCSC',
	'uscybergames':'US Cyber Games',
	'overthewire': 'OverTheWire',
};

const CTF_ORDER = ['itec', 'chronos', 'learn-it', 'cyberedu', 'uscybergames', 'overthewire', '__other__'];

const cheatSheets = [
	{ title: 'Forensics',        href: '/cheatsheets/forensics',  desc: 'Disk, memory, pcap, steganography' },
	{ title: 'Web',              href: '/cheatsheets/webapp',     desc: 'SQLi, XSS, SSRF, file inclusion, SSTI' },
	{ title: 'Linux / CLI',      href: '/cheatsheets/linux',      desc: 'Bandit-style challenges, file tricks, privilege escalation basics' },
	{ title: 'Crypto',           href: '/cheatsheets/crypto',     desc: 'Classical ciphers, RSA, hashing, encoding tricks' },
	{ title: 'Reversing',        href: '/cheatsheets/reversing',  desc: 'Ghidra, GDB, objdump, ltrace, patching binaries' },
	{ title: 'Pwn',              href: '/cheatsheets/pwn',        desc: 'Buffer overflows, ROP chains, pwntools, shellcode' },
	{ title: 'OSINT',            href: '/cheatsheets/osint',      desc: 'Username lookup, image geolocation, metadata, dorking' },
	{ title: 'Network',          href: '/cheatsheets/network',    desc: 'Wireshark filters, TCP/UDP analysis, protocol decoding' },
	{ title: 'Misc / Stego',     href: '/cheatsheets/misc',       desc: 'Steghide, LSB, QR codes, audio spectrograms, esoteric langs' },
];

/* Serialise only the fields the client script needs */
const postsData = allPosts.map((p) => ({
	id:    p.id,
	title: p.data.title,
	tags:  p.data.tags ?? [],
	date:  p.data.pubDate.toISOString(),
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts | ${SITE_TITLE}`} description="CTF write-ups and cheat sheets by m68k." />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── Cheat Sheets ── -->
			<section class="cheatsheets-section">
				<h1>Cheat Sheets</h1>
				<p class="section-desc">Quick references for common CTF categories.</p>
				<div class="cheatsheet-grid">
					{cheatSheets.map((cs) => (
						<a href={cs.href} class="cs-card">
							<span class="cs-title">{cs.title}</span>
							<span class="cs-desc">{cs.desc}</span>
						</a>
					))}
				</div>
			</section>

			<!-- ── Write-ups ── -->
			<section id="writeups-section">
				<div class="writeups-header">
					<h1>Write-ups</h1>
					<span id="page-indicator" class="page-indicator"></span>
				</div>

				<!-- Posts rendered by JS -->
				<div id="posts-container"></div>

				<!-- Pagination buttons -->
				<div id="pagination" class="pagination"></div>
			</section>

		</main>
		<Footer />

	</body>
</html>

<script define:vars={{ postsData }}>
const PAGE_SIZE = 15;

const CTF_LABEL = {
	'itec':         'ITEC 2025 CTF',
	'chronos':      'Chronos Security CTF 2025',
	'learn-it':     'Learn-it CTF',
	'cyberedu':     'CyberEdu / ROCSC',
	'uscybergames': 'US Cyber Games',
	'overthewire':  'OverTheWire',
};

const CTF_ORDER = ['itec', 'chronos', 'learn-it', 'cyberedu', 'uscybergames', 'overthewire', '__other__'];

const posts = postsData;

let currentPage = 0;
const pageCount = Math.ceil(posts.length / PAGE_SIZE);

const container   = document.getElementById('posts-container');
const pagination  = document.getElementById('pagination');
const indicator   = document.getElementById('page-indicator');

/* ── Helpers ── */

function groupPosts(pagePosts) {
	const map = {};
	for (const post of pagePosts) {
		const key = CTF_ORDER.find((k) => post.tags.includes(k)) ?? '__other__';
		if (!map[key]) map[key] = [];
		map[key].push(post);
	}
	return CTF_ORDER
		.filter((k) => map[k]?.length)
		.map((k) => ({
			key: k,
			label: k === '__other__' ? 'Other' : CTF_LABEL[k],
			posts: map[k],
		}));
}

function formatDate(iso) {
	return new Date(iso).toLocaleDateString('en-US', {
		month: 'short', day: 'numeric', year: 'numeric',
	});
}

/* ── Render ── */

function buildHTML(page) {
	const slice  = posts.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE);
	const groups = groupPosts(slice);

	return groups.map(({ key, label, posts: gPosts }) => `
		<div class="ctf-group">
			<h2 class="ctf-name">
				${label}
				<span class="count">${gPosts.length}</span>
			</h2>
			<ul>
				${gPosts.map((p) => `
					<li>
						<a href="/blog/${p.id}/" class="post-link">
							<span class="post-title">${p.title}</span>
							<div class="post-meta">
								<div class="tags">
									${p.tags.map((t) => `<span class="tag">${t}</span>`).join('')}
								</div>
								<time datetime="${p.date}">${formatDate(p.date)}</time>
							</div>
						</a>
					</li>
				`).join('')}
			</ul>
		</div>
	`).join('');
}

function renderPagination() {
	pagination.innerHTML = '';
	if (pageCount <= 1) return;

	for (let i = 0; i < pageCount; i++) {
		const btn = document.createElement('button');
		btn.textContent = String(i + 1);
		btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
		btn.addEventListener('click', () => {
			if (i !== currentPage) goToPage(i);
		});
		pagination.appendChild(btn);
	}
}

function renderIndicator() {
	if (pageCount <= 1) { indicator.textContent = ''; return; }
	indicator.textContent = `Page ${currentPage + 1} of ${pageCount}`;
}

async function goToPage(page) {
	/* fade out */
	container.classList.add('fade-out');
	await new Promise((r) => setTimeout(r, 180));

	currentPage = page;
	container.innerHTML = buildHTML(page);
	renderPagination();
	renderIndicator();

	/* fade in */
	container.classList.remove('fade-out');
	container.classList.add('fade-in');
	await new Promise((r) => setTimeout(r, 180));
	container.classList.remove('fade-in');

	/* scroll write-ups section into comfortable view */
	document.getElementById('writeups-section')
		.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

/* ── Init ── */
container.innerHTML = buildHTML(0);
renderPagination();
renderIndicator();
</script>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 3em;
	}

	h1 {
		font-size: 1.4em;
		margin-bottom: 1em;
	}

	/* ── Writeups header ── */
	.writeups-header {
		display: flex;
		align-items: baseline;
		gap: 1em;
		margin-bottom: 0;
	}

	.writeups-header h1 {
		margin-bottom: 0;
	}

	.page-indicator {
		font-size: 0.75em;
		color: var(--text-muted);
	}

	/* ── Fade animation ── */
	#posts-container {
		transition: opacity 0.18s ease, transform 0.18s ease;
	}

	#posts-container.fade-out {
		opacity: 0;
		transform: translateY(6px);
	}

	#posts-container.fade-in {
		opacity: 0;
		transform: translateY(-6px);
		animation: fadeIn 0.18s ease forwards;
	}

	@keyframes fadeIn {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* ── CTF groups ── */
	.ctf-group {
		margin-bottom: 2em;
	}

	.ctf-name {
		font-size: 0.8em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.4em;
		margin-bottom: 0.4em;
		display: flex;
		align-items: center;
		gap: 0.6em;
	}

	.count {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 1px 7px;
		font-size: 0.85em;
		color: var(--text-muted);
		font-weight: 400;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	li {
		border-bottom: 1px solid var(--border);
	}

	li:last-child {
		border-bottom: none;
	}

	.post-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.55em 0;
		gap: 1em;
		text-decoration: none;
		color: var(--text);
	}

	.post-link:hover .post-title {
		color: var(--accent);
	}

	.post-title {
		font-size: 0.9em;
		flex-shrink: 1;
		min-width: 0;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-shrink: 0;
	}

	.tags {
		display: flex;
		gap: 0.3em;
	}

	.tag {
		font-size: 0.68em;
		padding: 2px 7px;
		border-radius: 10px;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		color: var(--text-muted);
		white-space: nowrap;
	}

	time {
		font-size: 0.78em;
		color: var(--text-muted);
		white-space: nowrap;
	}

	/* ── Pagination ── */
	.pagination {
		display: flex;
		gap: 0.4em;
		margin-top: 1.5em;
	}

	.page-btn {
		min-width: 2em;
		padding: 0.3em 0.65em;
		font-size: 0.82em;
		font-family: inherit;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text-muted);
		cursor: pointer;
		transition: border-color 0.15s, color 0.15s, background 0.15s;
	}

	.page-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.page-btn.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
		font-weight: 600;
		cursor: default;
	}

	/* ── Cheat sheets ── */
	.cheatsheets-section {
		padding-top: 0.5em;
	}

	.section-desc {
		color: var(--text-muted);
		font-size: 0.875em;
		margin-top: -0.5em;
		margin-bottom: 1.25em;
	}

	.cheatsheet-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 0.75em;
	}

	.cs-card {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		padding: 1em 1.1em;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--bg-secondary);
		text-decoration: none;
		transition: border-color 0.15s, box-shadow 0.15s;
	}

	.cs-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 0 1px var(--accent);
	}

	.cs-title {
		font-weight: 600;
		font-size: 0.9em;
		color: var(--text);
	}

	.cs-desc {
		font-size: 0.78em;
		color: var(--text-muted);
	}

	@media (max-width: 600px) {
		.post-meta .tags {
			display: none;
		}
	}
</style>
