---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const CTF_LABEL: Record<string, string> = {
	'itec':        'ITEC 2025 CTF',
	'chronos':     'Chronos Security CTF 2025',
	'learn-it':    'Learn-it CTF',
	'cyberedu':    'CyberEdu / ROCSC',
	'uscybergames':'US Cyber Games',
	'overthewire': 'OverTheWire',
};

const CTF_ORDER = ['itec', 'chronos', 'learn-it', 'cyberedu', 'uscybergames', 'overthewire', '__other__'];

const cheatSheets = [
	{ title: 'Forensics',    icon: '🔍', href: '/cheatsheets/forensics',  desc: 'Disk, memory, pcap, steganography' },
	{ title: 'Web',          icon: '🌐', href: '/cheatsheets/webapp',     desc: 'SQLi, XSS, SSRF, file inclusion, SSTI' },
	{ title: 'Linux / CLI',  icon: '🐧', href: '/cheatsheets/linux',      desc: 'Bandit-style challenges, file tricks, privesc' },
	{ title: 'Crypto',       icon: '🔐', href: '/cheatsheets/crypto',     desc: 'Classical ciphers, RSA, hashing, encoding' },
	{ title: 'Reversing',    icon: '⚙️',  href: '/cheatsheets/reversing',  desc: 'Ghidra, GDB, objdump, ltrace, patching' },
	{ title: 'Pwn',          icon: '💥', href: '/cheatsheets/pwn',        desc: 'Buffer overflows, ROP chains, pwntools' },
	{ title: 'OSINT',        icon: '🕵️',  href: '/cheatsheets/osint',      desc: 'Username lookup, geolocation, dorking' },
	{ title: 'Network',      icon: '📡', href: '/cheatsheets/network',    desc: 'Wireshark, tshark, TCP/UDP, protocols' },
	{ title: 'Misc / Stego', icon: '🎨', href: '/cheatsheets/misc',       desc: 'Steghide, LSB, QR codes, esoteric langs' },
];

/* Serialise only the fields the client script needs */
const postsData = allPosts.map((p) => ({
	id:    p.id,
	title: p.data.title,
	tags:  p.data.tags ?? [],
	date:  p.data.pubDate.toISOString(),
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts | ${SITE_TITLE}`} description="CTF write-ups and cheat sheets by m68k." />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── Cheat Sheets ── -->
			<section class="cheatsheets-section">
				<div class="section-header">
					<h1>Cheat Sheets</h1>
					<p class="section-desc">Quick references for common CTF categories.</p>
				</div>
				<div class="cheatsheet-grid">
					{cheatSheets.map((cs) => (
						<a href={cs.href} class="cs-card">
							<span class="cs-icon">{cs.icon}</span>
							<span class="cs-title">{cs.title}</span>
							<span class="cs-desc">{cs.desc}</span>
						</a>
					))}
				</div>
			</section>

			<!-- ── Write-ups ── -->
			<section id="writeups-section">
				<div class="section-header writeups-header">
					<div class="writeups-title-row">
						<h1>Write-ups</h1>
						<span id="page-indicator" class="page-indicator"></span>
					</div>
					<p class="section-desc">CTF competition write-ups, grouped by event.</p>
				</div>

				<!-- Posts rendered by JS -->
				<div id="posts-container"></div>

				<!-- Pagination buttons -->
				<div id="pagination" class="pagination"></div>
			</section>

		</main>
		<Footer />

	</body>
</html>

<script define:vars={{ postsData }}>
const PAGE_SIZE = 15;

const CTF_LABEL = {
	'itec':         'ITEC 2025 CTF',
	'chronos':      'Chronos Security CTF 2025',
	'learn-it':     'Learn-it CTF',
	'cyberedu':     'CyberEdu / ROCSC',
	'uscybergames': 'US Cyber Games',
	'overthewire':  'OverTheWire',
};

const CTF_ORDER = ['itec', 'chronos', 'learn-it', 'cyberedu', 'uscybergames', 'overthewire', '__other__'];

const posts = postsData;

let currentPage = 0;
const pageCount = Math.ceil(posts.length / PAGE_SIZE);

const container  = document.getElementById('posts-container');
const pagination = document.getElementById('pagination');
const indicator  = document.getElementById('page-indicator');

/* ── Helpers ── */

function groupPosts(pagePosts) {
	const map = {};
	for (const post of pagePosts) {
		const key = CTF_ORDER.find((k) => post.tags.includes(k)) ?? '__other__';
		if (!map[key]) map[key] = [];
		map[key].push(post);
	}
	return CTF_ORDER
		.filter((k) => map[k]?.length)
		.map((k) => ({
			key: k,
			label: k === '__other__' ? 'Other' : CTF_LABEL[k],
			posts: map[k],
		}));
}

function formatDate(iso) {
	return new Date(iso).toLocaleDateString('en-US', {
		month: 'short', day: 'numeric', year: 'numeric',
	});
}

/* ── Render ── */

function buildHTML(page) {
	const slice  = posts.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE);
	const groups = groupPosts(slice);

	return groups.map(({ label, posts: gPosts }) => `
		<div class="ctf-group">
			<div class="ctf-name">
				<span class="ctf-label">${label}</span>
				<span class="count">${gPosts.length}</span>
			</div>
			<ul>
				${gPosts.map((p) => `
					<li>
						<a href="/blog/${p.id}/" class="post-link">
							<span class="post-title">${p.title}</span>
							<div class="post-meta">
								<div class="tags">
									${p.tags.map((t) => `<span class="tag">${t}</span>`).join('')}
								</div>
								<time datetime="${p.date}">${formatDate(p.date)}</time>
								<span class="arrow">→</span>
							</div>
						</a>
					</li>
				`).join('')}
			</ul>
		</div>
	`).join('');
}

function renderPagination() {
	pagination.innerHTML = '';
	if (pageCount <= 1) return;

	for (let i = 0; i < pageCount; i++) {
		const btn = document.createElement('button');
		btn.textContent = String(i + 1);
		btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
		btn.addEventListener('click', () => {
			if (i !== currentPage) goToPage(i);
		});
		pagination.appendChild(btn);
	}
}

function renderIndicator() {
	if (pageCount <= 1) { indicator.textContent = ''; return; }
	indicator.textContent = `${currentPage + 1} / ${pageCount}`;
}

async function goToPage(page) {
	container.classList.add('fade-out');
	await new Promise((r) => setTimeout(r, 160));

	currentPage = page;
	container.innerHTML = buildHTML(page);
	renderPagination();
	renderIndicator();

	container.classList.remove('fade-out');
	container.classList.add('fade-in');
	await new Promise((r) => setTimeout(r, 160));
	container.classList.remove('fade-in');

	document.getElementById('writeups-section')
		.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

/* ── Init ── */
container.innerHTML = buildHTML(0);
renderPagination();
renderIndicator();
</script>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 3.5em;
	}

	/* ── Section headers ── */
	.section-header {
		margin-bottom: 1.25em;
	}

	h1 {
		font-size: 1.3em;
		font-weight: 700;
		margin: 0 0 0.3em;
	}

	.section-desc {
		font-size: 0.82em;
		color: var(--text-muted);
		margin: 0;
	}

	/* ── Writeups header ── */
	.writeups-title-row {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}

	.page-indicator {
		font-size: 0.72em;
		color: var(--text-muted);
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 2px 9px;
		font-variant-numeric: tabular-nums;
	}

	/* ── Fade animation ── */
	#posts-container {
		transition: opacity 0.16s ease, transform 0.16s ease;
	}

	#posts-container.fade-out {
		opacity: 0;
		transform: translateY(8px);
	}

	#posts-container.fade-in {
		opacity: 0;
		transform: translateY(-8px);
		animation: fadeIn 0.16s ease forwards;
	}

	@keyframes fadeIn {
		to { opacity: 1; transform: translateY(0); }
	}

	/* ── CTF groups ── */
	.ctf-group {
		margin-bottom: 2em;
	}

	.ctf-name {
		display: flex;
		align-items: center;
		gap: 0.6em;
		padding-bottom: 0.5em;
		margin-bottom: 0.15em;
		border-bottom: 1px solid var(--border);
	}

	.ctf-label {
		font-size: 0.72em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
	}

	.count {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 1px 8px;
		font-size: 0.72em;
		color: var(--text-muted);
		font-weight: 400;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	li {
		border-bottom: 1px solid var(--border);
	}

	li:last-child {
		border-bottom: none;
	}

	/* ── Post rows ── */
	.post-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6em 0.5em 0.6em 0;
		gap: 1em;
		text-decoration: none;
		color: var(--text);
		border-radius: 4px;
		transition: background 0.12s ease, padding-left 0.12s ease;
	}

	.post-link:hover {
		padding-left: 0.5em;
		background: var(--bg-secondary);
	}

	.post-link:hover .post-title {
		color: var(--accent);
	}

	.post-link:hover .arrow {
		opacity: 1;
		transform: translateX(3px);
	}

	.post-title {
		font-size: 0.88em;
		flex-shrink: 1;
		min-width: 0;
		transition: color 0.12s ease;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		flex-shrink: 0;
	}

	.tags {
		display: flex;
		gap: 0.3em;
	}

	.tag {
		font-size: 0.65em;
		padding: 2px 7px;
		border-radius: 10px;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		color: var(--text-muted);
		white-space: nowrap;
	}

	time {
		font-size: 0.75em;
		color: var(--text-muted);
		white-space: nowrap;
		font-variant-numeric: tabular-nums;
	}

	.arrow {
		font-size: 0.8em;
		color: var(--accent);
		opacity: 0;
		transition: opacity 0.12s ease, transform 0.12s ease;
	}

	/* ── Pagination ── */
	.pagination {
		display: flex;
		gap: 0.35em;
		margin-top: 1.25em;
	}

	.page-btn {
		min-width: 2.1em;
		height: 2.1em;
		padding: 0 0.5em;
		font-size: 0.8em;
		font-family: inherit;
		font-weight: 500;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text-muted);
		cursor: pointer;
		transition: border-color 0.13s, color 0.13s, background 0.13s;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.page-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.page-btn.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
		font-weight: 700;
		cursor: default;
	}

	/* ── Cheat sheets ── */
	.cheatsheet-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 0.65em;
	}

	.cs-card {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
		padding: 0.9em 1em;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--bg-secondary);
		text-decoration: none;
		transition: border-color 0.13s, box-shadow 0.13s, transform 0.13s;
	}

	.cs-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 0 1px var(--accent);
		transform: translateY(-1px);
	}

	.cs-icon {
		font-size: 1.2em;
		line-height: 1;
		margin-bottom: 0.15em;
	}

	.cs-title {
		font-weight: 600;
		font-size: 0.88em;
		color: var(--text);
	}

	.cs-desc {
		font-size: 0.73em;
		color: var(--text-muted);
		line-height: 1.4;
	}

	/* ── Responsive ── */
	@media (max-width: 600px) {
		.post-meta .tags { display: none; }
		.arrow { display: none; }
		.cheatsheet-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
	}
</style>
