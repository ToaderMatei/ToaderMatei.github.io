---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const CTF_LABEL: Record<string, string> = {
	'itec':        'ITEC 2025 CTF',
	'chronos':     'Chronos Security CTF 2025',
	'learn-it':    'Learn-it CTF',
	'cyberedu':    'CyberEdu / ROCSC',
	'uscybergames':'US Cyber Games',
	'overthewire': 'OverTheWire',
};

const CTF_ORDER = ['itec', 'chronos', 'learn-it', 'cyberedu', 'uscybergames', 'overthewire', '__other__'];

type Post = typeof allPosts[number];

const grouped: Record<string, Post[]> = {};

for (const post of allPosts) {
	const tags: string[] = post.data.tags ?? [];
	const key = Object.keys(CTF_LABEL).find((k) => tags.includes(k)) ?? '__other__';
	if (!grouped[key]) grouped[key] = [];
	grouped[key].push(post);
}

const cheatSheets = [
	{ title: 'Forensics', href: '/cheatsheets/forensics', desc: 'Disk, memory, pcap, steganography' },
	{ title: 'Web', href: '/cheatsheets/webapp', desc: 'SQLi, XSS, SSRF, file inclusion, SSTI' },
	{ title: 'Linux / CLI', href: '/cheatsheets/linux', desc: 'Bandit-style challenges, file tricks, privilege escalation basics' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts | ${SITE_TITLE}`} description="CTF write-ups and cheat sheets by m68k." />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── Write-ups ── -->
			<section>
				<h1>Write-ups</h1>
				{CTF_ORDER.filter((k) => grouped[k]?.length).map((key) => (
					<div class="ctf-group">
						<h2 class="ctf-name">
							{key === '__other__' ? 'Other' : CTF_LABEL[key]}
							<span class="count">{grouped[key].length}</span>
						</h2>
						<ul>
							{grouped[key].map((post) => (
								<li>
									<a href={`/blog/${post.id}/`} class="post-link">
										<span class="post-title">{post.data.title}</span>
										<div class="post-meta">
											<div class="tags">
												{(post.data.tags ?? []).map((tag: string) => (
													<span class="tag">{tag}</span>
												))}
											</div>
											<time datetime={post.data.pubDate.toISOString()}>
												{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
											</time>
										</div>
									</a>
								</li>
							))}
						</ul>
					</div>
				))}
			</section>

			<!-- ── Cheat Sheets ── -->
			<section class="cheatsheets-section">
				<h1>Cheat Sheets</h1>
				<p class="section-desc">Quick references for common CTF categories.</p>
				<div class="cheatsheet-grid">
					{cheatSheets.map((cs) => (
						<a href={cs.href} class="cs-card">
							<span class="cs-title">{cs.title}</span>
							<span class="cs-desc">{cs.desc}</span>
						</a>
					))}
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 3em;
	}

	h1 {
		font-size: 1.4em;
		margin-bottom: 1em;
	}

	/* ── CTF groups ── */
	.ctf-group {
		margin-bottom: 2em;
	}

	.ctf-name {
		font-size: 0.8em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.4em;
		margin-bottom: 0.4em;
		display: flex;
		align-items: center;
		gap: 0.6em;
	}

	.count {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 1px 7px;
		font-size: 0.85em;
		color: var(--text-muted);
		font-weight: 400;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	li {
		border-bottom: 1px solid var(--border);
	}

	li:last-child {
		border-bottom: none;
	}

	.post-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.55em 0;
		gap: 1em;
		text-decoration: none;
		color: var(--text);
	}

	.post-link:hover .post-title {
		color: var(--accent);
		text-decoration: none;
	}

	.post-title {
		font-size: 0.9em;
		flex-shrink: 1;
		min-width: 0;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-shrink: 0;
	}

	.tags {
		display: flex;
		gap: 0.3em;
	}

	.tag {
		font-size: 0.68em;
		padding: 2px 7px;
		border-radius: 10px;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		color: var(--text-muted);
		white-space: nowrap;
	}

	time {
		font-size: 0.78em;
		color: var(--text-muted);
		white-space: nowrap;
	}

	/* ── Cheat sheets ── */
	.cheatsheets-section {
		padding-top: 0.5em;
	}

	.section-desc {
		color: var(--text-muted);
		font-size: 0.875em;
		margin-top: -0.5em;
		margin-bottom: 1.25em;
	}

	.cheatsheet-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 0.75em;
	}

	.cs-card {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		padding: 1em 1.1em;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--bg-secondary);
		text-decoration: none;
		transition: border-color 0.15s, box-shadow 0.15s;
	}

	.cs-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 0 1px var(--accent);
		text-decoration: none;
	}

	.cs-title {
		font-weight: 600;
		font-size: 0.9em;
		color: var(--text);
	}

	.cs-desc {
		font-size: 0.78em;
		color: var(--text-muted);
	}

	@media (max-width: 600px) {
		.post-meta .tags {
			display: none;
		}
	}
</style>
