---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const events = [
	{ name: 'DefCamp CTF 2024 Quals', place: 68, pts: '722', rating: '7.513' },
	{ name: 'DefCamp CTF 2025 Quals', place: 118, pts: '357', rating: '3.512' },
	{ name: 'Midnight Flag CTF - EXECUTION', place: 315, pts: '300', rating: '1.715' },
	{ name: 'Cyber Apocalypse CTF 2025', place: 2512, pts: '4425', rating: '1.872' },
	{ name: 'jailCTF 2025', place: 321, pts: '100', rating: '0.238' },
	{ name: 'TFC CTF 2024', place: 242, pts: '250', rating: '1.042' },
];

const members = [
	{ handle: 'm68k', url: 'https://ctftime.org/user/189835' },
	{ handle: 'Tal1banu', url: 'https://ctftime.org/user/189804' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About m68k." />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<div class="content">

				<!-- ── m68k callout ── -->
				<div class="m68k-callout reveal">
					<div class="m68k-callout-label">m68k</div>
					<p>
						The <strong>Motorola 68000</strong> is a 16/32-bit CISC processor released by Motorola in 1979.
						It powered the original Apple Macintosh, the Commodore Amiga, and the Atari ST.
						After desktops moved on, it lived inside millions of cable modems and routers — unpatched,
						forgotten, still online.
					</p>
					<p>
						When the <strong>Mirai</strong> botnet source leaked in 2016, its cross-compiler
						included an explicit <code>m68k</code> target. Those neglected routers became the
						foot-soldiers of record-breaking DDoS attacks — the 620 Gbps hit on
						<em>KrebsOnSecurity</em> and the Dyn attack that took down large parts of the internet
						for a day. Later variants (Satori, Okiru, Masuta) all kept hunting the same hardware.
					</p>
					<p class="m68k-callout-footer">
						Old, overlooked technology rarely disappears — it just accumulates attack surface.
					</p>
				</div>

				<p>
					Hey — I'm <strong>m68k</strong>, a student from Romania. I spend most of my free time
					playing CTF competitions and reading about security topics that probably have
					no practical use outside of CTFs.
				</p>
				<p>
					I started this site to keep track of the challenges I solve and to force myself
					to actually document my thought process instead of just moving on to the next one.
					If something here is useful to you, great. If not, at least I learned something writing it.
				</p>
				<p>
					I'm mostly interested in web exploitation, network forensics, and reverse engineering —
					though I'll try anything in a CTF.
				</p>

				<!-- ── Team ── -->
				<h2 class="reveal">Team</h2>
				<p>
					I play with <a href="https://ctftime.org/team/313771" target="_blank" class="team-link">NXLL</a>
					— a small Romanian CTF team. We've been competing since 2024, with our best result being
					<strong>68th place</strong> at DefCamp CTF 2024 Quals.
				</p>

				<div class="members reveal">
					{members.map((m) => (
						<a href={m.url} target="_blank" class="member">
							{m.handle}
						</a>
					))}
				</div>

				<h2 class="reveal">CTF Results</h2>
				<div class="table-wrap reveal">
					<table>
						<thead>
							<tr>
								<th>Event</th>
								<th>Place</th>
								<th>Points</th>
								<th>Rating</th>
							</tr>
						</thead>
						<tbody>
							{events.map((e) => (
								<tr>
									<td>{e.name}</td>
									<td class="num">#{e.place}</td>
									<td class="num">{e.pts}</td>
									<td class="num">{e.rating}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
				<p class="ctftime-link">
					<a href="https://ctftime.org/team/313771" target="_blank">View full profile on CTFtime →</a>
				</p>

				<!-- ── Contact ── -->
				<h2 class="reveal">Contact</h2>
				<ul class="reveal">
					<li>
						<span class="label">GitHub</span>
						<a href="https://github.com/ToaderMatei" target="_blank">ToaderMatei</a>
					</li>
					<li>
						<span class="label">Discord</span>
						<span>m68k.</span>
					</li>
					<li>
						<span class="label">Email</span>
						<a href="mailto:contact@m68k.ro">contact@m68k.ro</a>
					</li>
					<li>
						<span class="label">CTFtime</span>
						<a href="https://ctftime.org/user/189835" target="_blank">m68k</a>
					</li>
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 1.5em;
		margin-bottom: 1.5em;
	}

	/* ── m68k callout ── */
	.m68k-callout {
		position: relative;
		border: 1px solid var(--accent);
		border-radius: 8px;
		padding: 1.4em 1.5em 1.2em;
		margin-bottom: 2em;
		background: color-mix(in srgb, var(--accent) 5%, transparent);
	}

	.m68k-callout-label {
		position: absolute;
		top: -0.65em;
		left: 1em;
		background: var(--bg);
		padding: 0 0.5em;
		font-size: 0.7em;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
		font-family: 'Fira Code', 'Consolas', monospace;
	}

	.m68k-callout p {
		color: var(--text-muted);
		font-size: 0.88em;
		line-height: 1.75;
		margin-bottom: 0.8em;
	}

	.m68k-callout p:last-child {
		margin-bottom: 0;
	}

	.m68k-callout strong {
		color: var(--text);
	}

	.m68k-callout code {
		font-family: 'Fira Code', 'Consolas', monospace;
		font-size: 0.9em;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		padding: 1px 5px;
		border-radius: 3px;
	}

	.m68k-callout-footer {
		font-size: 0.82em !important;
		font-style: italic;
		color: var(--text-muted);
		opacity: 0.75;
		border-top: 1px solid var(--border);
		padding-top: 0.75em;
		margin-top: 0.5em;
	}

	h2 {
		font-size: 0.8em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin: 2.25em 0 1em;
		font-weight: 600;
	}

	.content {
		max-width: 620px;
	}

	.content p {
		color: var(--text-muted);
		font-size: 0.95em;
		line-height: 1.8;
		margin-bottom: 1.1em;
	}

	.content p strong {
		color: var(--text);
	}

	.team-link {
		color: var(--accent);
		font-weight: 600;
	}

	/* Members */
	.members {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
		margin-bottom: 1.5em;
	}

	.member {
		font-size: 0.85em;
		padding: 4px 12px;
		border-radius: 20px;
		border: 1px solid var(--border);
		background: var(--bg-secondary);
		color: var(--text);
		text-decoration: none;
		transition: border-color 0.15s;
	}

	.member:hover {
		border-color: var(--accent);
		color: var(--accent);
		text-decoration: none;
	}

	/* Table */
	.table-wrap {
		overflow-x: auto;
		border: 1px solid var(--border);
		border-radius: 8px;
		margin-bottom: 0.75em;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.85em;
	}

	thead th {
		padding: 0.6em 1em;
		text-align: left;
		font-size: 0.75em;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		border-bottom: 1px solid var(--border);
	}

	tbody tr {
		border-bottom: 1px solid var(--border);
	}

	tbody tr:last-child {
		border-bottom: none;
	}

	tbody tr:hover {
		background: var(--bg-secondary);
	}

	td {
		padding: 0.55em 1em;
		color: var(--text-muted);
	}

	td:first-child {
		color: var(--text);
	}

	.num {
		font-variant-numeric: tabular-nums;
		text-align: right;
		white-space: nowrap;
	}

	.ctftime-link {
		font-size: 0.82em !important;
	}

	.ctftime-link a {
		color: var(--accent);
	}

	/* Contact list */
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6em;
	}

	li {
		display: flex;
		gap: 1.5em;
		font-size: 0.9em;
		align-items: baseline;
	}

	.label {
		color: var(--text-muted);
		min-width: 60px;
		font-size: 0.85em;
	}
</style>
