---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Write-ups | ${SITE_TITLE}`} description="CTF write-ups and security research." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Write-ups</h1>
			{posts.length === 0 ? (
				<p class="empty">No posts yet.</p>
			) : (
				<ul>
					{posts.map((post) => (
						<li>
							<div class="post-info">
								<a href={`/blog/${post.id}/`} class="post-title">{post.data.title}</a>
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="tags">
										{post.data.tags.slice(0, 3).map((tag: string) => (
											<span class="tag">{tag}</span>
										))}
									</div>
								)}
							</div>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 1.5em;
		margin-bottom: 1.5em;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	li {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1em;
		padding: 0.75em 0;
		border-bottom: 1px solid var(--border);
	}

	li:last-child {
		border-bottom: none;
	}

	.post-info {
		display: flex;
		align-items: center;
		gap: 0.75em;
		min-width: 0;
	}

	.post-title {
		color: var(--text);
		font-size: 0.9em;
	}

	.post-title:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.tags {
		display: flex;
		gap: 0.3em;
		flex-shrink: 0;
	}

	.tag {
		font-size: 0.7em;
		padding: 2px 7px;
		border-radius: 10px;
		background-color: var(--bg-secondary);
		border: 1px solid var(--border);
		color: var(--text-muted);
		white-space: nowrap;
	}

	.date {
		color: var(--text-muted);
		font-size: 0.8em;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.empty {
		color: var(--text-muted);
	}

	@media (max-width: 560px) {
		.tags { display: none; }
	}
</style>
